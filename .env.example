# Lya Rooms - Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-publishable-key-here

# Lya Rooms - Vercel Blob Storage Configuration
# Get these values from Vercel Dashboard > Storage > Blob > Tokens
VITE_STORAGE_PROVIDER=vercel_blob
VERCEL_BLOB_STORE_ID=store_xxx
VERCEL_BLOB_BASE_URL=https://xxx.private.blob.vercel-storage.com
BLOB_READ_WRITE_TOKEN=your-vercel-blob-read-write-token